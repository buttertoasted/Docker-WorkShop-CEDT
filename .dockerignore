# TODO(step-3): list paths that must NOT be copied into the Docker build context.
# Required entries: node_modules, .git, .env, npm-debug.log, Dockerfile, .github, .dockerignore itself
#
# NOTE: .dockerignore only affects `docker build` (what lands in the build context).
# It does NOT affect `docker compose` bind mounts. Do not add `app/db/` or `*.sql`
# here, or the image will build without seed data paths being reachable.
#
# (Fill in the list below.)

# Dependency directories
node_modules
npm-debug.log

# Version control
.git
.github

# Secret and Local Environment files
.env

# Docker files (preventing the builder from copying its own instructions)
Dockerfile
.dockerignore